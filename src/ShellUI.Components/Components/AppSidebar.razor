            IconClass = "fa-solid fa-microchip",
            SubItems = new()
            {
                new SubNavItem { Title = "Genesis", Url = "#" },
                new SubNavItem { Title = "Explorer", Url = "#" },
                new SubNavItem { Title = "Quantum", Url = "#" }
            }
        },
        new NavItem
        {
            Title = "Documentation",
            Url = "#",
            IconClass = "fa-solid fa-book",
            SubItems = new()
            {
                new SubNavItem { Title = "Introduction", Url = "#" },
                new SubNavItem { Title = "Get Started", Url = "#" },
                new SubNavItem { Title = "Tutorials", Url = "#" },
                new SubNavItem { Title = "Changelog", Url = "#" }
            }
        },
        new NavItem
        {
            Title = "Settings",
            Url = "#",
            IconClass = "fa-solid fa-gear",
            SubItems = new()
            {
                new SubNavItem { Title = "General", Url = "#" },
                new SubNavItem { Title = "Team", Url = "#" },
                new SubNavItem { Title = "Billing", Url = "#" },
                new SubNavItem { Title = "Limits", Url = "#" }
            }
        }
    };

    private readonly List<ProjectItem> _projects = new()
    {
        new ProjectItem
        {
            Name = "Design Engineering",
