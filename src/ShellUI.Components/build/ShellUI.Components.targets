  <Target Name="WriteShellUISafelist"
          BeforeTargets="BeforeBuild;PrepareForBuild"
          Condition="'$(SkipShellUISafelist)' != 'true'">
    <MakeDir Directories="$(MSBuildProjectDirectory)/wwwroot" Condition="!Exists('$(MSBuildProjectDirectory)/wwwroot')" />
    <WriteLinesToFile File="$(MSBuildProjectDirectory)/wwwroot/shellui-classes.txt"
                      Lines="@(ShellUISafelistEntry)"
                      Overwrite="true" />
  </Target>
