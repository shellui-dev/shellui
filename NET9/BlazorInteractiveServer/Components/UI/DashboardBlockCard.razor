@* Renders dashboard block inside a bounded container (shadcn-style) *@
<div class="h-full min-h-0 flex overflow-hidden">
<SidebarProvider Class="!min-h-0 h-full flex-1 min-h-0">
    <AppSidebar />
    <SidebarInset>
        <header class="@(StickyHeader ? "sticky top-0 z-10 bg-background" : "") flex h-14 shrink-0 items-center gap-2 border-b border-border px-3">
            <SidebarTrigger Class="-ml-1 shrink-0" />
            <Separator Orientation="vertical" Class="mr-2 h-3 shrink-0" />
            <Breadcrumb Class="flex flex-1 min-w-0 items-center text-sm">
                <BreadcrumbItem Href="/">Home</BreadcrumbItem>
                <BreadcrumbItem Href="/blocks">Blocks</BreadcrumbItem>
                <BreadcrumbItem IsLast="true">Preview</BreadcrumbItem>
            </Breadcrumb>
            <ThemeToggle Size="sm" Variant="outline" Class="ml-auto shrink-0" />
        </header>
        <div class="flex flex-1 flex-col gap-3 overflow-auto p-3">
            <div class="grid grid-cols-3 gap-2">
                <div class="aspect-video rounded-lg bg-muted/50" />
                <div class="aspect-video rounded-lg bg-muted/50" />
                <div class="aspect-video rounded-lg bg-muted/50" />
            </div>
            <div class="min-h-[60px] flex-1 rounded-lg bg-muted/50" />
        </div>
    </SidebarInset>
</SidebarProvider>
</div>

@code {
    [Parameter] public bool StickyHeader { get; set; }
}
