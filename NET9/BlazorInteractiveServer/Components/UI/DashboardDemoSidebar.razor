@namespace BlazorInteractiveServer.Components.UI

@* Demo sidebar for block previews — generic dashboard-style nav, NOT the main app sidebar *@
<Sidebar Variant="SidebarVariant.Inset" Collapsible="SidebarCollapsible.Icon" Class="@Class">
    <SidebarHeader>
        <SidebarMenu>
            <SidebarMenuItem>
                @* Swapped: light shows dark-style icon (white bg, dark logo), dark shows light-style icon (dark bg, light logo) *@
                <SidebarMenuButton Size="lg" Href="#" Tooltip="ShellUI" Class="group-data-[collapsible=icon]:!bg-white group-data-[collapsible=icon]:!text-black dark:group-data-[collapsible=icon]:!bg-black dark:group-data-[collapsible=icon]:!text-white">
                    <ShellUILogo Size="32" Class="shrink-0 text-sidebar-foreground group-data-[collapsible=icon]:!text-black dark:group-data-[collapsible=icon]:!text-white" />
                    <div class="grid min-w-0 flex-1 text-left text-sm leading-tight group-data-[collapsible=icon]:hidden">
                        <span class="truncate font-semibold">ShellUI</span>
                        <span class="truncate text-xs text-sidebar-foreground/70">Demo layout</span>
                    </div>
                </SidebarMenuButton>
            </SidebarMenuItem>
        </SidebarMenu>
    </SidebarHeader>

    <SidebarContent>
        <SidebarGroup>
            <SidebarGroupLabel>Main</SidebarGroupLabel>
            <SidebarGroupContent>
                <SidebarMenu>
                    <SidebarMenuItem>
                        <SidebarMenuButton Href="#" Tooltip="Home">
                            <i class="fa-solid fa-house"></i>
                            <span>Home</span>
                        </SidebarMenuButton>
                    </SidebarMenuItem>
                    <SidebarMenuItem>
                        <SidebarMenuButton Href="#" Tooltip="Analytics">
                            <i class="fa-solid fa-chart-line"></i>
                            <span>Analytics</span>
                        </SidebarMenuButton>
                    </SidebarMenuItem>
                    <SidebarMenuItem>
                        <SidebarMenuButton Href="#" Tooltip="Reports">
                            <i class="fa-solid fa-file-lines"></i>
                            <span>Reports</span>
                        </SidebarMenuButton>
                    </SidebarMenuItem>
                </SidebarMenu>
            </SidebarGroupContent>
        </SidebarGroup>

        <SidebarGroup>
            <SidebarGroupLabel>Settings</SidebarGroupLabel>
            <SidebarGroupContent>
                <SidebarMenu>
                    <SidebarMenuItem>
                        <SidebarMenuButton Href="#" Tooltip="Profile">
                            <i class="fa-solid fa-user"></i>
                            <span>Profile</span>
                        </SidebarMenuButton>
                    </SidebarMenuItem>
                    <SidebarMenuItem>
                        <SidebarMenuButton Href="#" Tooltip="Settings">
                            <i class="fa-solid fa-gear"></i>
                            <span>Settings</span>
                        </SidebarMenuButton>
                    </SidebarMenuItem>
                </SidebarMenu>
            </SidebarGroupContent>
        </SidebarGroup>

        <SidebarGroup Class="mt-auto">
            <SidebarGroupContent>
                <SidebarMenu>
                    <SidebarMenuItem>
                        <SidebarMenuButton Href="#" Tooltip="Shewart Shepherd" Size="default"
                            Class="bg-sidebar-accent text-sidebar-accent-foreground hover:bg-sidebar-accent/90">
                            @* Wrapped in div: SidebarMenuButton hides [&>span] when collapsed, Avatar renders span - div keeps it visible *@
                            <div class="shrink-0">
                                <Avatar Fallback="SS" Class="h-8 w-8 rounded-full [&>span]:!bg-sidebar-accent [&>span]:!text-sidebar-accent-foreground [&>span]:!font-semibold [&>span]:!text-sm" />
                            </div>
                            <div class="grid min-w-0 flex-1 text-left leading-tight group-data-[collapsible=icon]:hidden">
                                <span class="truncate font-medium">Shewart Shepherd</span>
                                <span class="truncate text-xs opacity-90">shepherd@shellui.dev</span>
                            </div>
                        </SidebarMenuButton>
                    </SidebarMenuItem>
                </SidebarMenu>
            </SidebarGroupContent>
        </SidebarGroup>
    </SidebarContent>
</Sidebar>

@code {
    [Parameter] public string? Class { get; set; }
}
