    }

    private class UserProfile
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Initials { get; set; } = "";
    }

    // ── User ──
    private readonly UserProfile _user = new()
    {
        Name = "shadcn",
        Email = "m@example.com",
        Initials = "CN"
    };

    // ── Navigation Data ──
    private readonly List<NavItem> _navMainItems = new()
    {
        new NavItem
        {
