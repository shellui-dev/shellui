            SubItems = new()
            {
                new SubNavItem { Title = "Introduction", Url = "#" },
                new SubNavItem { Title = "Get Started", Url = "#" },
                new SubNavItem { Title = "Tutorials", Url = "#" },
                new SubNavItem { Title = "Changelog", Url = "#" }
            }
        },
        new NavItem
        {
            Title = "Settings",
            Url = "#",
            IconClass = "fa-solid fa-gear",
            SubItems = new()
            {
                new SubNavItem { Title = "General", Url = "#" },
