@page "/"

<PageTitle>ShellUI Components</PageTitle>

<div class="w-fit max-w-5xl mx-auto px-6 py-10">
    <div class="mb-8">
        <h1 class="text-2xl font-semibold tracking-tight text-foreground">ShellUI Components</h1>
        <p class="mt-1 text-sm text-muted-foreground">Click a component to view its preview.</p>
    </div>

    <Separator Class="mb-6" />

    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2">
        @foreach (var item in _components)
        {
            <a href="/preview/@item.Id"
               class="flex flex-col items-center gap-2 rounded-lg border border-border bg-card px-3 py-3 text-center text-xs font-medium text-foreground transition-colors hover:border-primary/50 hover:bg-accent/50 min-w-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-muted/60 text-muted-foreground [&>svg]:size-4">
                    @((MarkupString)item.IconSvg)
                </span>
                <span class="truncate w-full">@item.Label</span>
            </a>
        }
    </div>
</div>

