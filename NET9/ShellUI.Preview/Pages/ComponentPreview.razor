@page "/preview/{ComponentName}"
@layout Layout.PreviewLayout
@using ShellUI.Components
@using ShellUI.Components.Models
@using ShellUI.Preview.Components

<div class="preview-container">
    @switch (_id)
    {
        case "button":
            <Button Variant="@_buttonVariant" Size="@_buttonSize">Button</Button>
            break;
        case "badge":
            <Badge Variant="@_badgeVariant">Badge</Badge>
            break;
        case "switch":
            <Switch />
            break;
        case "checkbox":
            <Checkbox Label="Accept terms" />
            break;
        case "input":
            <Input Placeholder="Type something..." />
            break;
        case "textarea":
            <Textarea Placeholder="Enter your message..." Class="min-h-[100px] w-full max-w-md" />
            break;
        case "alert":
            <Alert Variant="@_alertVariant" Title="Heads up!">You can add components to your app using the cli.</Alert>
            break;
        case "card":
            <Card Class="w-[350px]">
                <CardHeader>
                    <CardTitle>Create project</CardTitle>
                    <CardDescription>Deploy your new project in one-click.</CardDescription>
                </CardHeader>
                <CardContent>
                    <p class="text-sm text-muted-foreground">Card Content Area</p>
                </CardContent>
                <CardFooter>
                    <Button>Deploy</Button>
                </CardFooter>
            </Card>
            break;
        case "tabs":
            <Tabs Items="@_tabItems" Class="w-[400px]" />
            break;
        case "combobox":
            <Combobox Options="@_comboboxOptions" Placeholder="Select framework..." />
            break;
        case "select":
            <div class="w-full max-w-[200px]">
                <Select @bind-Value="_selectValue">
                    <option value="">Choose...</option>
                    <option value="a">Option A</option>
                    <option value="b">Option B</option>
                    <option value="c">Option C</option>
                </Select>
            </div>
            break;
        case "datepicker":
            <DatePicker />
            break;
        case "skeleton":
            <div class="flex items-center space-x-4">
                <Skeleton Class="h-12 w-12 rounded-full" />
                <div class="space-y-2">
                    <Skeleton Class="h-4 w-[250px]" />
                    <Skeleton Class="h-4 w-[200px]" />
                </div>
            </div>
            break;
        case "dialog":
            <DialogPreview />
            break;
        case "accordion":
            <Accordion>
                <AccordionItem Title="Is it accessible?">
                    <p class="text-sm text-muted-foreground">Yes. It adheres to the WAI-ARIA design pattern.</p>
                </AccordionItem>
                <AccordionItem Title="Is it styled?">
                    <p class="text-sm text-muted-foreground">Yes. It comes with default styles.</p>
                </AccordionItem>
                <AccordionItem Title="Is it animated?">
                    <p class="text-sm text-muted-foreground">Yes. Animated with Tailwind CSS transitions.</p>
                </AccordionItem>
            </Accordion>
            break;
        case "avatar":
            <div class="flex items-center gap-4">
                <Avatar Fallback="AB" />
                <Avatar Fallback="CD" Class="h-10 w-10" />
                <Avatar Fallback="EF" Class="h-14 w-14" />
            </div>
            break;
        case "breadcrumb":
            <Breadcrumb>
                <BreadcrumbItem Href="/">Home</BreadcrumbItem>
                <BreadcrumbItem Href="/components">Components</BreadcrumbItem>
                <BreadcrumbItem IsLast="true">Breadcrumb</BreadcrumbItem>
            </Breadcrumb>
            break;
        case "progress":
            <div class="space-y-4 w-full max-w-xs">
                <Progress Value="@(33)" />
                <Progress Value="@(66)" />
                <Progress Value="@(100)" />
            </div>
            break;
        case "slider":
            <div class="w-full max-w-xs">
                <Slider Value="@(50)" />
            </div>
            break;
        case "separator":
            <div class="flex flex-col gap-4 w-full max-w-xs">
                <div class="space-y-1">
                    <h4 class="text-sm font-medium">Section</h4>
                    <p class="text-sm text-muted-foreground">Content above separator.</p>
                </div>
                <Separator />
                <div class="space-y-1">
                    <h4 class="text-sm font-medium">Section</h4>
                    <p class="text-sm text-muted-foreground">Content below separator.</p>
                </div>
            </div>
            break;
        case "label":
            <div class="space-y-2">
                <Label>Your email</Label>
                <Input Placeholder="name@example.com" Type="email" />
            </div>
            break;
        case "toggle":
            <Toggle>Toggle</Toggle>
            break;
        case "dashboard-01":
        case "dashboard-02":
            <div class="w-full max-w-4xl">
                <div class="rounded-xl border border-border bg-card shadow-sm overflow-hidden" style="min-height: 520px; height: 560px;">
                    <DashboardBlockPreview StickyHeader="@(_id == "dashboard-02")" />
                </div>
                <p class="mt-2 text-xs text-muted-foreground">@(_id == "dashboard-02" ? "Sticky header (breadcrumb bar stays fixed on scroll)" : "Header scrolls with content")</p>
            </div>
            break;
        default:
            <div class="text-muted-foreground text-sm">
                Component <span class="font-mono bg-muted px-1 rounded">@ComponentName</span> not found.
            </div>
            break;
    }
</div>

@code {
    [Parameter] public string ComponentName { get; set; } = "";

    [SupplyParameterFromQuery] public string? Variant { get; set; }
    [SupplyParameterFromQuery] public string? Size { get; set; }

    private string _id => ComponentName?.ToLowerInvariant() ?? "";

    private ButtonVariant _buttonVariant => Enum.TryParse<ButtonVariant>(Variant, true, out var v) ? v : ButtonVariant.Default;
    private ButtonSize _buttonSize => Enum.TryParse<ButtonSize>(Size, true, out var s) ? s : ButtonSize.Default;
    private BadgeVariant _badgeVariant => Enum.TryParse<BadgeVariant>(Variant, true, out var b) ? b : BadgeVariant.Default;
    private AlertVariant _alertVariant => Enum.TryParse<AlertVariant>(Variant, true, out var a) ? a : AlertVariant.Default;

    private List<TabItem> _tabItems => new()
    {
        new() { Id = "account", Label = "Account", Content = b => b.AddMarkupContent(0, "<div class='p-4 border rounded mt-2'>Account settings here.</div>") },
        new() { Id = "password", Label = "Password", Content = b => b.AddMarkupContent(0, "<div class='p-4 border rounded mt-2'>Change password here.</div>") }
    };

    private List<string> _comboboxOptions => new() { "Next.js", "SvelteKit", "Nuxt.js", "Remix", "Astro" };

    private string _selectValue { get; set; } = "";
}
